# --- secrets / env files ---
# Real env files are never tracked; *.example files are the templates and
# ARE meant to be tracked (explicitly re-allowed below).
.env
.env.local
.env.*.local
!.env.example
!.env.local.example
!**/*.env.example
!**/*.env.local.example

# --- Python / backend ---
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# --- Node / frontend build artifacts ---
node_modules/
.next/
out/
build/
*.tsbuildinfo
.vercel

# --- logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
cloudflared_out.log
cloudflared_err.log

# --- throwaway / diagnostic scripts ---
scratch_*.py
*_scratch.py

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- IDE / editor ---
.vscode/
.idea/

# --- Claude Code local settings (machine-local, not shared config) ---
.claude/settings.local.json